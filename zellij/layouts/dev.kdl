layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }
    tab name="Neovim" focus=true {
        pane command="bash" {
            args "-c" "[ -f .venv/bin/activate ] && source .venv/bin/activate || [ -f backend/.venv/bin/activate ] && source backend/.venv/bin/activate; exec nvim"
        }
    }
    tab name="OpenCode" {
        pane command="bash" {
            args "-c" "if [ -n \"$OPENCODE_MESSAGE\" ]; then exec opencode run \"$OPENCODE_MESSAGE\"; else exec opencode; fi"
        }
    }
    tab name="Terminal" {
        pane 
    }
}
