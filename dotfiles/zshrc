# workon: Start or attach to a Zellij session for the current directory
# Usage: workon [--fresh] [folder]
workon() {
  local fresh=0
  local target_dir="."

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --fresh)
        fresh=1
        shift
        ;;
      *)
        target_dir="$1"
        shift
        ;;
    esac
  done

  local resolved_dir=$(cd "$target_dir" 2>/dev/null && pwd)
  if [[ -z "$resolved_dir" ]]; then
    echo "Error: Directory '$target_dir' not found"
    return 1
  fi

  local session_name="${resolved_dir##*/}"
  session_name="${session_name//./-}"

  if [[ "$fresh" -eq 1 ]]; then
    local fresh_session_name="${session_name}-fresh-$(date +%H%M%S)"
    (cd "$resolved_dir" && zellij -n dev -s "$fresh_session_name")
  else
    if [[ -n "$ZELLIJ" ]]; then
      if ! zellij action switch-session --cwd "$resolved_dir" "$session_name"; then
        zellij action switch-session --cwd "$resolved_dir" --layout dev "$session_name"
      fi
    else
      (cd "$resolved_dir" && zellij --layout dev attach -c "$session_name")
    fi
  fi
}

wts() {
  if ! command -v wt >/dev/null 2>&1; then
    echo "Error: wt command not found"
    return 1
  fi

  local has_branch=0
  local arg
  for arg in "$@"; do
    if [[ "$arg" == "--" ]]; then
      break
    fi
    if [[ "$arg" == "-" || "$arg" == "^" || "$arg" == "@" || "$arg" != -* ]]; then
      has_branch=1
      break
    fi
  done

  if [[ "$has_branch" -eq 1 ]]; then
    wt switch --no-cd -x 'workon "{{ worktree_path }}"' "$@"
    return
  fi

  local selected_branch
  selected_branch=$(wt switch --no-cd "$@") || return 1
  if [[ -z "$selected_branch" ]]; then
    return 1
  fi

  wt switch --no-cd -x 'workon "{{ worktree_path }}"' "$selected_branch"
}

# workon-issue: Prepare issue worktree and open dev session with OpenCode message
# Usage: workon-issue [--fresh] <issue-number>
workon-issue() {
  local fresh=0
  local issue_number=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --fresh)
        fresh=1
        shift
        ;;
      -* )
        echo "Error: Unknown option '$1'"
        echo "Usage: workon-issue [--fresh] <issue-number>"
        return 1
        ;;
      *)
        if [[ -n "$issue_number" ]]; then
          echo "Error: Only one issue number is supported"
          echo "Usage: workon-issue [--fresh] <issue-number>"
          return 1
        fi
        issue_number="$1"
        shift
        ;;
    esac
  done

  if [[ -z "$issue_number" ]]; then
    echo "Usage: workon-issue [--fresh] <issue-number>"
    return 1
  fi

  local configs_dir="$HOME/source/configs"
  local start_issue_script="$configs_dir/scripts/start-issue.sh"
  local repo_root
  local setup_output
  local worktree_path=""
  local prompt_file=""

  if [[ ! -x "$start_issue_script" ]]; then
    echo "Error: '$start_issue_script' not found or not executable"
    return 1
  fi

  repo_root=$(git rev-parse --show-toplevel 2>/dev/null)
  if [[ -z "$repo_root" ]]; then
    echo "Error: workon-issue must be run inside a git repository"
    return 1
  fi

  if ! setup_output=$(cd "$repo_root" && "$start_issue_script" --no-launch "$issue_number"); then
    return 1
  fi

  while IFS= read -r line; do
    case "$line" in
      WORKTREE_PATH=*) worktree_path="${line#WORKTREE_PATH=}" ;;
      PROMPT_FILE=*) prompt_file="${line#PROMPT_FILE=}" ;;
    esac
  done <<< "$setup_output"

  if [[ -z "$worktree_path" ]]; then
    echo "Error: Could not determine worktree path from start-issue output"
    return 1
  fi

  if [[ -z "$prompt_file" ]]; then
    prompt_file="$worktree_path/.issue-prompt.md"
  fi

  local session_name="issue-${issue_number}"

  if [[ ! -f "$prompt_file" ]]; then
    echo "Error: Prompt file not found at '$prompt_file'"
    return 1
  fi

  if [[ "$fresh" -eq 1 ]]; then
    local fresh_session_name="${session_name}-fresh-$(date +%H%M%S)"
    (
      cd "$worktree_path" || exit 1
      export OPENCODE_MESSAGE="$(<"$prompt_file")"
      zellij --layout dev -n dev -s "$fresh_session_name"
    )
  else
    (
      cd "$worktree_path" || exit 1
      export OPENCODE_MESSAGE="$(<"$prompt_file")"
      zellij --layout dev attach -c "$session_name"
    )
  fi
}

